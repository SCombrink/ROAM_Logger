# Aider AI assistant files
.aider*

# Dependencies (NEVER commit - regenerated by 'npm install')
node_modules/

# Tauri build artifacts (NEVER commit - regenerated by 'tauri build')
src-tauri/target/
src-tauri/gen/

# Frontend build output (NEVER commit - regenerated by 'npm run build')
dist/
.vite/

# Local history / backups
.diffflow_history/
*.bak

# Updater signing keys - CRITICAL: NEVER commit
*.key
*.key.pub
.tauri/

# Environment files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp

# OS metadata
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Stray / temporary files
src-tauri/2

# Personal Aider AI assistant tooling (not part of the app)
Aider*.txt
Start-Aider.ps1
startaider*.lnk
list_files.py
